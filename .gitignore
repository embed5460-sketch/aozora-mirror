# 第三方原始语料（575MB，通过 git clone aozorabunko_text 获取，见 README）
/Tools/

# 下载的元数据（可重新下载，见 README）；但保留外字映射表（gaiji.mjs 运行时依赖，仅 312KB）
/pipeline/data/*
!/pipeline/data/jisx0213-2004-std.txt

# 生成产物（由 pipeline 脚本重建）
/pipeline/out/parsed/
/pipeline/out/preview.html
/pipeline/out/missing-files.json

# 部署产物（Vercel 静态托管，Root Directory=cdn）：catalog/meta.json 入库；
# 正文 JSON 体量大（~257MB/4798 文件），试水阶段先 git add -f 放入子集验证链路，
# 全量上线时再删除下面这行放开 books/。
/cdn/books/*

# Android 构建产物与本机配置
/android/.gradle/
/android/build/
/android/app/build/
/android/captures/
/android/local.properties
/android/.kotlin/
/android/app/release/
*.apk
*.aab

# 依赖与系统文件
node_modules/
*.log
.DS_Store
Thumbs.db
