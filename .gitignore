# 第三方原始语料（575MB，通过 git clone aozorabunko_text 获取，见 README）
/Tools/

# 下载的元数据（可重新下载，见 README）；但保留外字映射表（gaiji.mjs 运行时依赖，仅 312KB）
/pipeline/data/*
!/pipeline/data/jisx0213-2004-std.txt

# 生成产物（由 pipeline 脚本重建）
/pipeline/out/parsed/
/pipeline/out/preview.html
/pipeline/out/missing-files.json

# 部署产物全量入库（Vercel 静态托管，Root Directory=cdn）：catalog/meta.json +
# 4798 本正文 JSON 全部跟踪。链路已验证：git push → Gitee → GitHub 镜像 → Vercel。
# 注：cdn/ 由 pipeline 的 build-catalog.mjs 重建，但因走 git 镜像部署需常驻仓库。

