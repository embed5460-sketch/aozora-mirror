さ"},{"t":"ぃおらだなぃな。"},{"b":"誰","f":"だれ"},{"t":"だってきれいなものすぎさな。おれだって"},{"b":"伊手","f":"いで"},{"t":"ででもいいあねこ見ればその話だてするさ。あのあんこだて"},{"b":"好","f":"す"},{"t":"ぎだべ。好ぎだて云え。こう云うごとほんと云うごそ"},{"b":"実","f":"じつ"},{"t":"ぁあるづもんだ。な。好ぎだべ。）おみちは"},{"b":"子供","f":"こども"},{"t":"のようにうなずいた。嘉吉はまだくしゃくしゃ"},{"b":"泣","f":"な"},{"t":"いておどけたような顔をしたおみちを"},{"b":"抱","f":"だ"},{"t":"いてこっそり耳へささやいた。（そだがらさ、あのあんこ"},{"b":"肴","f":"さかな"},{"t":"にして今日ぁ遊ぶべじゃい。いいが。おれあのあんこうなさ"},{"b":"取","f":"と"},{"t":"り"},{"b":"持","f":"も"},{"t":"づ。"},{"b":"大丈夫","f":"だいじょうぶ"},{"t":"だでばよ。おれこれがら"},{"b":"出掛","f":"でか"},{"t":"げて"},{"b":"峠","f":"とうげ"},{"t":"さ行ぐまでに行ぎあって今夜の"},{"b":"踊","f":"おど"},{"t":"り見るべしてすすめるがらよ、なあにどごまで行がなぃやなぃようだなぃがけな。そして踊り"},{"b":"済","f":"す"},{"t":"まってがら家さ"},{"b":"連","f":"つ"},{"t":"れで来ておれ"},{"b":"実家","f":"じっか"},{"t":"さ行って"},{"b":"泊","f":"とま"},{"t":"って来るがらうなこっちで泣いて"},{"b":"頼","f":"たの"},{"t":"んでみなよ。おれの妹だって云えばいいがらよ。そしてさ出来ればよ、うなも町さ出はてもうんといい女子だづごともわがら。）"}]},{"k":"p","r":[{"t":"　おみちの"},{"b":"胸","f":"むね"},{"t":"はこの"},{"b":"悪魔","f":"あくま"},{"t":"のささやきにどかどか鳴った。それからいきなり"},{"b":"嘉吉","f":"かきち"},{"t":"をとび"},{"b":"退","f":"の"},{"t":"いて、"}]},{"k":"p","r":[{"t":"（何云うべ、この人あ、人ばがにして。）そして"},{"b":"爽","f":"さわや"},{"t":"かに"},{"b":"笑","f":"わら"},{"t":"った。嘉吉もごろりと"},{"b":"寝","f":"ね"},{"t":"そべって"},{"b":"天井","f":"てんじょう"},{"t":"を見ながら何べんも笑った。そこでおみちははじめて晴れ晴れじぶんの"},{"b":"拵","f":"こしら"},{"t":"えた"},{"b":"寒天","f":"かんてん"},{"t":"もたべた。"},{"b":"餅","f":"もち"},{"t":"もたべた。キャラメルの"},{"b":"箱","f":"はこ"},{"t":"と"},{"b":"敷島","f":"しきしま"},{"t":"は秋らしい日光のなかにしずかに"},{"b":"横","f":"よこた"},{"t":"わった。"}]}]}