{"id":"007931","title":"秋の夜","author":"宮本百合子","authorId":"000311","blocks":[{"k":"p","r":[{"t":"月そそぐいずの夜"}]},{"k":"p","r":[{"t":"揺れ揺れて流れ行く光りの中に"}]},{"k":"p","r":[{"t":"音もなく一人もだし立てば"}]},{"k":"p","r":[{"t":"萌え出でし思いのかいわれ葉"}]},{"k":"p","r":[{"t":"瑞木となりて空に冲る。"}]},{"k":"blank"},{"k":"p","r":[{"t":"乾坤を照し尽す無量光"}]},{"k":"p","r":[{"t":"埴の星さえ輝き初め"}]},{"k":"p","r":[{"t":"我踏む土は尊や白埴"}]},{"k":"p","r":[{"t":"木ぐれに潜む物の隈なく"}]},{"k":"p","r":[{"t":"黄朽ち葉を装いなすは"}]},{"k":"p","r":[{"t":"夜光の玉か神のみすまるか"}]},{"k":"p","r":[{"t":"奇しき光りよ。"}]},{"k":"blank"},{"k":"p","r":[{"t":"常珍らなるかかる夜は"}]},{"k":"p","r":[{"t":"炫燿郷の十二宮"}]},{"k":"p","r":[{"t":"眼くるめく月の宮"}]},{"k":"p","r":[{"t":"瑠璃の階　八尋どの"}]},{"k":"p","r":[{"t":"玉のわたどの踏みならし"}]},{"k":"p","r":[{"t":"打ち連れ舞わん桂乙女"}]},{"k":"p","r":[{"t":"うまし眉高く　やさめの輝き"}]},{"k":"p","r":[{"t":"長袖花をあざむけば"}]},{"k":"p","r":[{"t":"天馳つかい喜び誦し"}]},{"k":"p","r":[{"t":"山祇もみずとりだまも"}]},{"k":"p","r":[{"t":"ともに奏でん玉の緒琴　箏の笛"}]},{"k":"blank"},{"k":"p","r":[{"t":"妙なりや秋の夜"}]},{"k":"p","r":[{"t":"心ゆく今の一とき"}]},{"k":"p","r":[{"t":"久遠劫なる月の栄え"}]},{"k":"p","r":[{"t":"讚えんに言の葉も得ず"}]},{"k":"p","r":[{"t":"いずのみお我辺かこむ。"}]}]}