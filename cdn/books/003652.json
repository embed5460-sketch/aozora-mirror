","r":[{"t":"　と"},{"b":"呼吸","f":"いき"},{"t":"の下で云うと、襟の白さが、"},{"b":"颯","f":"さっ"},{"t":"と紫を"},{"b":"蔽","f":"おお"},{"t":"うように、はなじろんで顔をうつむけた。"}]},{"k":"p","r":[{"t":"　赤ら顔は"},{"b":"見免","f":"みのが"},{"t":"さない。"}]},{"k":"p","r":[{"t":"「お前、どうしたのかねえ。」"}]},{"k":"p","r":[{"t":"　かの男はと見ると、ちょうどその順が来たのかどうか、くしゃくしゃと両手で"},{"b":"頭髪","f":"かみ"},{"t":"を"},{"b":"掻","f":"かき"},{"t":"しゃなぐる、中折帽も床に落ちた、夢中で"},{"b":"引挘","f":"ひんむし"},{"t":"る。"}]},{"k":"p","r":[{"t":"「革鞄に挟った。」"}]},{"k":"p","r":[{"t":"「どうしてな。」"}]},{"k":"p","r":[{"t":"　と二三人立掛ける。"}]},{"k":"p","r":[{"t":"　窓へ、や、えんこらさ、と"},{"b":"攀上","f":"よじのぼ"},{"t":"った若いものがある。"}]},{"k":"p","r":[{"t":"　駅夫の長い腕が"},{"b":"引払","f":"ひッぱら"},{"t":"った。"}]},{"k":"p","r":[{"t":"　笛は、"},{"b":"胡桃","f":"くるみ"},{"t":"を割る駒鳥の声のごとく、山野に響く。"}]},{"k":"p","r":[{"t":"　汽車は"},{"b":"猶予","f":"ためら"},{"t":"わず出た。"}]},{"k":"p","r":[{"t":"　一人"},{"b":"発奮","f":"はずみ"},{"t":"をくって、のめりかかったので、"},{"b":"雪頽","f":"なだれ"},{"t":"を打ったが、それも、赤ら顔の手も"},{"b":"交","f":"まじ"},{"t":"って、三四人大革鞄に"},{"b":"取","f":"とり"},{"t":"かかった。"}]},{"k":"p","r":[{"t":"「これは貴方のですか。」"}]},{"k":"p","r":[{"t":"　で、その答も待たずに、口を開けようとするのである。"}]},{"k":"p","r":[{"t":"　なかなかもって、どうして古狸の老武者が、そんな事で"},{"b":"行","f":"ゆ"},{"t":"くものか。"}]},{"k":"p","r":[{"t":"「これは堅い、堅い。」"}]},{"k":"p","r":[{"t":"「巌丈な金具じゃええ。」"}]},{"k":"p","r":[{"t":"　それ言わぬ事ではない。"}]},{"k":"p","r":[{"t":"「こりゃ開かぬ、"},{"b":"鍵","f":"かぎ"},{"t":"が締まってるんじゃい。」"}]},{"k":"p","r":[{"t":"　と一まず手を引いたのは、"},{"b":"茶紬","f":"ちゃつむぎ"},{"t":"の"},{"b":"親仁","f":"おやじ"},{"t":"で。"}]},{"k":"p","r":[{"t":"　成程、と"},{"b":"解","f":"よ"},{"t":"めた風で、皆白けて控えた。"},{"b":"更","f":"あらた"},{"t":"めて、新しく立ちかかったものもあった。"}]},{"k":"p","r":[{"t":"　室内は"},{"b":"動揺","f":"どよ"},{"t":"む。"},{"b":"嬰児","f":"こども"},{"t":"は泣く。汽車は"},{"b":"轟","f":"とどろ"},{"t":"く。"},{"b":"街樹","f":"なみき"},{"t":"は流るる。"}]},{"k":"p","r":[{"t":"「誰の"},{"b":"麁匇","f":"そそう"},{"t":"じゃい。」"}]},{"k":"p","r":[{"t":"　と赤ら顔はいよいよ赤くなって、例の白目で、じろり、と一ツずつ、女と、男とを見た。"}]},{"k":"p","r":[{"t":"　彼は"},{"b":"仰向","f":"あおむ"},{"t":"けに目を"},{"b":"瞑","f":"つぶ"},{"t":"った。"},{"b":"瞼","f":"まぶた"},{"t":"を掛けて、朱を"},{"b":"灌","f":"そそ"},{"t":"ぐ、――二合"},{"b":"壜","f":"びん"},{"t":"は、帽子とともに倒れていた――そして、しかと腕を"},{"b":"拱","f":"こまぬ"},{"t":"く。"}]},{"k":"p","r":[{"t":"　女は"},{"b":"頤","f":"おとがい"},{"t":"深く、優しらしい眉が前髪に透いて、ただ"},{"b":"差俯向","f":"さしうつむ"},{"t":"く。"}]},{"k":"blank"},{"k":"p","r":[{"t":"　　　　　　　六"}]},{"k":"blank"},{"k":"p","r":[{"t":"「この次で"},{"b":"下車","f":"おり"},{"t":"るのじゃに。」"}]},{"k":"p","r":[{"t":"　となぜか、わけも知らない娘を"},{"b":"躾","f":"たしな"},{"t":"めるように云って、片目を男にじろりと向け直して、"}]},{"k":"p","r":[{"t":"「何てまあ、馬鹿々々しい。」"}]},{"k":"p","r":[{"t":"　と"},{"b":"当着","f":"あてつ"},{"t":"けるように言った。"}]},{"k":"p","r":[{"t":"　が、まだ二人ともなにも言わなかった時、"},{"b":"連","f":"つれ"},{"t":"と目配せをしながら、赤ら顔の"},{"b":"継母","f":"ままおや"},{"t":"は"},{"b":"更","f":"あらた"},{"t":"めて、男の前にわざとらしく小腰、――と云っても大きい――を"},{"b":"屈","f":"かが"},{"t":"めた。"}]},{"k":"p","r":[{"t":"　"},{"b":"突如","f":"いきなり"},{"b":"噛着","f":"かみつ"},{"t":"き兼ねない剣幕だったのが、"},{"b":"飜","f":"ひるがえ"},{"t":"ってこの"},{"b":"慇懃","f":"いんぎん"},{"t":"な態度に出たのは、人は"},{"b":"須","f":"すべか"},{"t":"らく"},{"b":"渠等","f":"かれら"},{"t":"に対して洋服を着るべきである。"}]},{"k":"p","r":[{"t":"　赤ら顔は悪く切口上で、"}]},{"k":"p","r":[{"t":"「旦那、どちらの"},{"b":"麁匇","f":"そそう"},{"t":"か存じましないけれども、で、ございますね。飛んだことでございます。この娘は嫁にやります大切な"},{"b":"身体","f":"からだ"},{"t":"でございます。はい、鍵をお出し下さいまし、鍵をでございますな、旦那。」"}]},{"k":"p","r":[{"t":"　声が"},{"b":"眉間","f":"みけん"},{"t":"を射たように、旅客は苦しげに眉を"},{"b":"顰","f":"ひそ"},{"t":"めながら、"}]},{"k":"p","r":[{"t":"「鍵はありません。」"}]},{"k":"p","r":[{"t":"「ございませんと？……」"}]},{"k":"p","r":[{"t":"「鍵は棄てました。」"}]},{"k":"p","r":[{"t":"　とぶるぶると胴震いをすると、翼を開いたように肩で"},{"b":"掻縮","f":"かいちぢ"},{"t":"めた腕組を"},{"b":"衝","f":"つ"},{"t":"と解いて、一度"},{"b":"投出","f":"ほうりだ"},{"t":"すごとくばたりと落した。その手で、"},{"b":"挫","f":"ひし"},{"t":"ぐばかり"},{"b":"確","f":"しか"},{"t":"と"},{"b":"膝頭","f":"ひざがしら"},{"t":"を"},{"b":"掴","f":"つか"},{"t":"んで、"},{"b":"呼吸","f":"いき"},{"t":"が切れそうな"},{"b":"咳","f":"せき"},{"t":"を続けざまにしたが、決然としてすっくと立った。"}]},{"k":"p","r":[{"t":"「ちょっと御挨拶を申上げます、……同室の御婦人、紳士の方々も、失礼ながらお"},{"b":"聞取","f":"ききとり"},{"t":"を願いとうございます。"},{"b":"私","f":"わたくし"},{"t":"は、ここに隣席においでになる、"},{"b":"窈窕","f":"ようちょう"},{"t":"たる淑女。」"}]},{"k":"p","r":[{"t":"　彼は窈窕たる淑女と云った。"}]},{"k":"p","r":[{"t":"「この令嬢の袖を、"},{"b":"袂","f":"たもと"},{"t":"をでございます。口へ挟みました旅行革鞄の持主であります。挟んだのは、諸君。」"}]},{"k":"p","r":[{"t":"　と"},{"b":"眗","f":"みまわ"},{"t":"す目が空ざまに天井に上ずって、"}]},{"k":"p","r":[{"t":"「……申兼ねましたが"},{"b":"私","f":"わたくし"},{"t":"です。もっともはじめから、もくろんで致したのではありません。袂が革鞄の中に入っていたのは偶然であったのです。"}]},{"k":"p","r":[{"t":"　退屈まぎれに見ておりました旅行案内を、もとへ"},{"b":"突込","f":"つっこ"},{"t":"んで、革鞄の口をかしりと"},{"b":"啣","f":"くわ"},{"t":"えさせました時、フト柔かな、滑かな、ふっくりと美しいものを、きしりと"},{"b":"縊","f":"くび"},{"t":"って、"},{"b":"引緊","f":"ひきし"},{"t":"めたと思う"},{"b":"手応","f":"てごたえ"},{"t":"がありました。"}]},{"k":"p","r":[{"t":"　"},{"b":"真白","f":"まっしろ"},{"t":"な"},{"b":"薄","f":"すすき"},{"t":"の穂か、窓へ散込んだ"},{"b":"錦葉","f":"もみじ"},{"t":"の"},{"b":"一葉","f":"ひとは"},{"t":"、"},{"b":"散際","f":"ちりぎわ"},{"t":"のまだ血も"},{"b":"呼吸","f":"いき"},{"t":"も通うのを、"},{"b":"引挟","f":"ひっぱさ"},{"t":"んだのかと思ったのは事実であります。"}]},{"k":"p","r":[{"t":"　それが紫に"},{"b":"緋","f":"ひ"},{"t":"を"},{"b":"襲","f":"かさ"},{"t":"ねた、かくのごとく"},{"b":"盛粧","f":"せいしょう"},{"t":"された片袖の端、……すなわち人間界における天人の羽衣の羽の一枚であったのです。"}]},{"k":"p","r":[{"t":"　諸君、"},{"b":"私","f":"わたくし"},{"t":"は謹んで、これなる令嬢の淑徳と貞操を保証いたします。……令嬢は"},{"b":"未","f":"いま"},{"t":"だかつて一度も"},{"b":"私","f":"わたくし"},{"t":"ごときものに、ただ姿さへ御見せなすった、いや、むしろ見られた事さえお有んなさらない。"}]},{"k":"p","r":[{"t":"　東京でも、上野でも、途中でも、日本国において、"},{"b":"私","f":"わたくし"},{"t":"がこの令嬢を見ましたのは、今しがた革鞄の口に袖の挟まったのをはじめて心着きましたその瞬間におけるのみなのです。"}]},{"k":"p","r":[{"t":"　お見受け申すと、これから結婚の式にお臨みになるようなんです。"}]},{"k":"p","r":[{"t":"　いや、ようなんですぐらいだったら、"},{"b":"私","f":"わたくし"},{"t":"もかような"},{"b":"不埒","f":"ふらち"},{"t":"、不心得、失礼なことはいたさなかったろうと思います。"}]},{"k":"p","r":[{"t":"　"},{"b":"確","f":"たしか"},{"t":"に御縁着きになる。……双方の御親属に向って、御縁女の純潔を"},{"b":"更","f":"あらた"},{"t":"めて確証いたします。室内の方々も、願わくはこの令嬢のために保証にお立ちを願いたいのです。"}]},{"k":"p","r":[{"t":"　余り唐突な"},{"b":"狼藉","f":"ろうぜき"},{"t":"ですから、何かその縁組について、"},{"b":"私","f":"わたくし"},{"t":"のために、意趣遺恨でもお受けになるような前事が有るかとお思われになっては、なおこの上にも身の置き処がありませんから――」"}]},{"k":"blank"},{"k":"p","r":[{"t":"　　　　　　　七"}]},{"k":"blank"},{"k":"p","r":[{"t":"「実に、"},{"b":"寸毫","f":"すんごう"},{"t":"といえども意趣遺恨はありません。けれども、未練と、"},{"b":"執着","f":"しゅうぢゃく"},{"t":"と、"},{"b":"愚癡","f":"ぐち"},{"t":"と、卑劣と、悪趣と、"},{"b":"怨念","f":"おんねん"},{"t":"と、もっと"},{"b":"直截","f":"ちょくせつ"},{"t":"に申せば、狂乱があったのです。"}]},{"k":"p","r":[{"t":"　"},{"b":"狂気","f":"きちがい"},{"t":"が。」"}]},{"k":"p","r":[{"t":"　と"},{"b":"吻","f":"ほっ"},{"t":"と息して、……"}]},{"k":"p","r":[{"t":"「汽車の室内で隣合って一目見た、早やたちまち、次か、二ツ目か、少くともその次の駅では、人妻におなりになる。プラットフォームも婚礼に"},{"b":"出迎","f":"でむかい"},{"t":"の人橋で、直ちに婿君の家の廊下をお渡りなさるんだと思うと、つい知らず我を忘れて、カチリと"},{"b":"錠","f":"じょう"},{"t":"を"},{"b":"下","f":"おろ"},{"t":"しました。乳房に五寸釘を打たれるように、この御縁女はお驚きになったろうと存じます。優雅、"},{"b":"温柔","f":"おんじゅう"},{"t":"でおいでなさる、心弱い"},{"b":"女性","f":"にょしょう"},{"t":"は、さような狼藉にも、人中の身を恥じて、"},{"b":"端","f":"はした"},{"t":"なく声をお立てにならないのだと存じました。"}]},{"k":"p","r":[{"t":"　しかし、ただいま、席をお立ちになった"},{"b":"御容子","f":"ごようす"},{"t":"を見れば、その時まで何事も御存じではなかったのが分って、お心遣いの時間が五分たりとも少なかった、のみならず、お"},{"b":"身体","f":"からだ"},{"t":"の一箇処にも"},{"b":"紅","f":"あか"},{"t":"い点も着かなかった事を、――実際、錠をおろした途端には、髪"},{"b":"一条","f":"ひとすじ"},{"t":"の根にも血をお出しなすったろうと思いました――この祝言を守護する、黄道吉日の手に感謝します。"}]},{"k":"p","r":[{"t":"　けれども、それもただわずかの間で、今の"},{"b":"思","f":"おもい"},{"t":"はどうおいでなさるだろうと御推察申上げるばかりなのです。"}]},{"k":"p","r":[{"t":"　自白した罪人はここに"},{"b":"居","f":"お"},{"t":"ります。"},{"b":"遁","f":"にげ"},{"t":"も隠れもしませんから、"},{"b":"憚","f":"はばか"},{"t":"りながら、"},{"b":"御萱堂","f":"ごけんどう"},{"t":"とお見受け申します年配の御婦人は、"},{"b":"私","f":"わたくし"},{"t":"の前をお離れになって、お引添いの上。傷心した、かよわい令嬢の、"},{"b":"背","f":"せな"},{"t":"を抱く御介抱が願いたい。」"}]},{"k":"p","r":[{"t":"　一室は"},{"b":"悉","f":"ことごと"},{"t":"く目を注いだ、が、淑女は"},{"b":"崩折","f":"くずお"},{"t":"れもせず、"},{"b":"柔","f":"やわらか"},{"t":"な"},{"b":"褄","f":"つま"},{"t":"はずれの、"},{"b":"彩","f":"いろ"},{"t":"ある横縦の微線さえ、ただ美しく玉に刻まれたもののようである。"}]},{"k":"p","r":[{"t":"　ひとりかの男のみ、堅く"},{"b":"突立","f":"つった"},{"t":"って、頬を"},{"b":"傾","f":"かし"},{"t":"げて、女を見返ることさえ"},{"b":"得","f":"え"},{"t":"しない。"}]},{"k":"p","r":[{"t":"　赤ら顔も足も動かさなかった。"}]},{"k":"p","r":[{"t":"「あまつさえ、乱暴とも狼藉とも申しようのない、未練と、執着と、愚癡と、卑劣と、悪趣と、怨念と、なおその上にほとんど狂乱だと申しました。"}]},{"k":"p","r":[{"t":"　外ではありません。それの革鞄の"},{"b":"鍵","f":"かぎ"},{"t":"を棄てた事です。"},{"b":"私","f":"わたくし"},{"t":"は、この、この窓から"},{"b":"遥","f":"はるか"},{"t":"に"},{"b":"巽","f":"たつみ"},{"t":"の"},{"b":"天","f":"そら"},{"t":"に雪を銀線のごとく"},{"b":"刺繍","f":"ぬいとり"},{"t":"した、あの、遠山の頂を望んで投げたのです。……"},{"b":"私","f":"わたくし"},{"t":"は目を"},{"b":"瞑","f":"つぶ"},{"t":"った、ほとんだ気が"},{"b":"狂","f":"ちが"},{"t":"ったのだとお察しを願いたい。"}]},{"k":"p","r":[{"t":"　"},{"b":"為業","f":"しわざ"},{"t":"は"},{"b":"狂人","f":"きちがい"},{"t":"です、狂人は御覧のごとく、浅間しい人間の区々たる一個の"},{"b":"私","f":"わたくし"},{"t":"です。"}]},{"k":"p","r":[{"t":"　が、鍵は宇宙が奪いました、これは永遠に捜せますまい。"},{"b":"発見","f":"みいだ"},{"t":"せますまい、決して帰らない、戻りますまい。"}]},{"k":"p","r":[{"t":"　"},{"b":"小刀","f":"こがたな"},{"t":"をお持ちの方は革鞄をお破り下さい。力ある方は口を取ってお裂き下さい。それはいかようとも御随意です。"}]},{"k":"p","r":[{"t":"　鍵は投棄てました、決心をしたのです。"},{"b":"私","f":"わたくし"},{"t":"は皆さんが、たといいかなる手段をもってお迫りになろうとも、自分でこの革鞄は開けないのです。令嬢の袖は放さないのです。"}]},{"k":"p","r":[{"t":"　ただし、この革鞄の中には、"},{"b":"私","f":"わたくし"},{"t":"一身に取って、大切な書類、器具、物品、軽少にもしろ、あらゆる財産、一切の身代、祖先、父母の"},{"b":"位牌","f":"いはい"},{"t":"。実際、生命と"},{"b":"斉","f":"ひと"},{"t":"しいものを残らず"},{"b":"納","f":"い"},{"t":"れてあるのです。"}]},{"k":"p","r":[{"t":"　が、開けない以上は、誓って、一冊の旅行案内といえども取出さない事を盟約する。"}]},{"k":"p","r":[{"t":"　小出しの外、旅費もこの中にある、……野宿する覚悟です。"}]},{"k":"p","r":[{"t":"　"},{"b":"私","f":"わたくし"},{"t":"は――」"}]},{"k":"p","r":[{"t":"　とここで"},{"b":"名告","f":"なの"},{"t":"った。"}]},{"k":"blank"},{"k":"p","r":[{"t":"　　　　　　　八"}]},{"k":"blank"},{"k":"p","r":[{"t":"「年は三十七です。"},{"b":"私","f":"わたくし"},{"t":"は"},{"b":"逓信","f":"ていしん"},{"t":"省に勤めた小官吏です。この度飛騨の国の山中、一小寒村の郵便局に電信の技手となって赴任する第一の午前。」"}]},{"k":"p","r":[{"t":"　と"},{"b":"俯向","f":"うつむ"},{"t":"いて探って、鉄縁の時計を見た。"}]},{"k":"p","r":[{"t":"「零時四十三分です。この汽車は八分に着く。……"}]},{"k":"p","r":[{"t":"　令嬢の御一行は、次の宿で御下車だと承ります。"}]},{"k":"p","r":[{"t":"　駅員に御話しになろうと、巡査にお引渡しになろうと、それはしかし御随意です。"}]},{"k":"p","r":[{"t":"　また、同室の方々にも申上げます。御婦人、紳士方が、社会道徳の規律に因って、相当の御制裁を御満足にお加えを願う。それは甘んじて受けます。"}]},{"k":"p","r":[{"t":"　いずれも命を致さねばなりますまい。"}]},{"k":"p","r":[{"t":"　それは、しかし"},{"b":"厭","f":"いと"},{"t":"いません。"}]},{"k":"p","r":[{"t":"　が、ただここに、あらゆる罪科、一切の制裁の"},{"b":"中","f":"うち"},{"t":"に、"},{"b":"私","f":"わたくし"},{"t":"が最も苦痛を感ずるのは、この革鞄と、袖と、令嬢とともに、"},{"b":"私","f":"わたくし"},{"t":"が連れられて、"},{"b":"膝行","f":"しっこう"},{"t":"して当日の婿君の前に参る事です。"}]},{"k":"p","r":[{"t":"　"},{"b":"絞罪","f":"こうざい"},{"t":"より、"},{"b":"斬首","f":"ざんしゅ"},{"t":"より、その極刑をお撰びなさるが"},{"b":"宜","f":"よろ"},{"t":"しい。"}]},{"k":"p","r":[{"t":"　途中、"},{"b":"田畝","f":"たんぼ"},{"t":"道で自殺をしますまでも、"},{"b":"私","f":"わたくし"},{"t":"は、しかしながらお従い申さねばなりますまい。"}]},{"k":"p","r":[{"t":"　あるいは、革鞄をお切りなさるか、お裂きになるか。……"}]},{"k":"p","r":[{"t":"　すべて、いささかも"},{"b":"御斟酌","f":"ごしんしゃく"},{"t":"に及びません。"}]},{"k":"p","r":[{"t":"　諸君が"},{"b":"姑息","f":"こそく"},{"t":"の慈善心をもって、"},{"b":"些少","f":"さしょう"},{"t":"なりとも、ために御斟酌下さろうかと思う、父母も親類も何にもない。"}]},{"k":"p","r":[{"t":"　"},{"b":"妻女","f":"かない"},{"t":"は亡くなりました、それは一昨年です。最愛の妻でした。」"}]},{"k":"p","r":[{"t":"　彼は口"},{"b":"吃","f":"きっ"},{"t":"しつつ"},{"b":"目瞬","f":"またたき"},{"t":"した。"}]},{"k":"p","r":[{"t":"「一人の"},{"b":"小児","f":"こども"},{"t":"も亡くなりました、それはこの夏です。可愛い"},{"b":"児","f":"こ"},{"t":"でした。」"}]},{"k":"p","r":[{"t":"　と云う時、せぐりくる胸や支え兼ねけん、"},{"b":"睫","f":"まつげ"},{"t":"を濡らした。"}]},{"k":"p","r":[{"t":"「"},{"b":"妻","f":"かない"},{"t":"の"},{"b":"記念","f":"かたみ"},{"t":"だったのです。二人の白骨もともに、革鞄の中にあります。墓も一まとめに持って行くのです。"}]},{"k":"p","r":[{"t":"　感ずる"},{"b":"仔細","f":"しさい"},{"t":"がありまして、"},{"b":"私","f":"わたくし"},{"t":"は望んで"},{"b":"僻境","f":"へききょう"},{"t":"孤立の、奥"},{"b":"山家","f":"やまが"},{"t":"の電信技手に転任されたのです。この職務は、人間の生活に暗号を与えるのです。一種絶島の燈台守です。"}]},{"k":"p","r":[{"t":"　そこにおいて、終生……つまらなく言えば"},{"b":"囲炉裡端","f":"いろりばた"},{"t":"の火打石です。神聖に云えば霊山における電光です。瞬間に人間の運命を照らす、仙人の黒き符のごとき電信の文字を司ろうと思うのです。"}]},{"k":"p","r":[{"t":"　が、辞令も革鞄に封じました。受持の室の扉を開けるにも、"},{"b":"鍵","f":"かぎ"},{"t":"がなければなりません。"}]},{"k":"p","r":[{"t":"　鍵は棄てたんです。"}]},{"k":"p","r":[{"t":"　令嬢の袖の奥へ魂は納めました。"}]},{"k":"p","r":[{"t":"　誓って"},{"b":"私","f":"わたくし"},{"t":"は革鞄を開けない。"}]},{"k":"p","r":[{"t":"　御親類の方々、他に御婦人、紳士諸君、御随意に適当の御制裁、御手段が願いたい。"}]},{"k":"p","r":[{"t":"　お"},{"b":"聴","f":"きき"},{"t":"を煩らわしました。――別に申す事はありません。」"}]},{"k":"p","r":[{"t":"　彼は、"},{"b":"従容","f":"しょうよう"},{"t":"として席に復した。が、あまたたび額の汗を"},{"b":"拭","f":"ぬぐ"},{"t":"った。汗は氷のごとく冷たかろう、と私は思わず"},{"b":"慄然","f":"りつぜん"},{"t":"とした。"}]},{"k":"p","r":[{"t":"　室内は"},{"b":"寂然","f":"ひっそり"},{"t":"した。彼の言は、"},{"b":"明晰","f":"めいせき"},{"t":"に、口"},{"b":"吃","f":"きっ"},{"t":"しつつも"},{"b":"流暢","f":"りゅうちょう"},{"t":"沈着であった。この独白に対して、汽車の"},{"b":"轟","f":"とどろき"},{"t":"は、一種のオオケストラを聞くがごときものであった。"}]},{"k":"p","r":[{"t":"　"},{"b":"停車場","f":"ステイション"},{"t":"に着くと、"},{"b":"湧返","f":"わきかえ"},{"t":"ったその混雑さ。"}]},{"k":"p","r":[{"t":"　羽織、袴、白襟、紋着、迎いの人数がずらりと並ぶ、礼服を着た"},{"b":"一揆","f":"いっき"},{"t":"を思え。"}]},{"k":"p","r":[{"t":"　時に、"},{"b":"継母","f":"ままおや"},{"t":"の取った手段は、極めて平凡な、しかも"},{"b":"最上","f":"もっとも"},{"t":"常識的なものであった。"}]},{"k":"p","r":[{"t":"「旦那、この革鞄だけ持って出ますでな。」"}]},{"k":"p","r":[{"t":"「いいえ、貴方。」"}]},{"k":"p","r":[{"t":"　"},{"b":"判然","f":"はっきり"},{"t":"した優しい"},{"b":"含声","f":"ふくみごえ"},{"t":"で、"},{"b":"屹","f":"きっ"},{"t":"と"},{"b":"留","f":"とど"},{"t":"めた女が、八ツ口に手を掛ける、と口を添えて、"},{"b":"袖着","f":"そでつけ"},{"t":"の糸をきりきりと裂いた、籠めたる心に"},{"b":"揺","f":"ゆら"},{"t":"めく黒髪、島田は、黄金の"},{"b":"高彫","f":"たかぼり"},{"t":"した、輝く"},{"b":"斧","f":"おの"},{"t":"のごとくに見えた。"}]},{"k":"p","r":[{"t":"　紫の"},{"b":"襲","f":"かさね"},{"t":"の片袖、紋清らかに革鞄に落ちて、"},{"b":"膚","f":"はだ"},{"t":"を裂いたか、女の片身に、"},{"b":"颯","f":"さっ"},{"t":"と流るる"},{"b":"襦袢","f":"じゅばん"},{"t":"の"},{"b":"緋鹿子","f":"ひがのこ"},{"t":"。"}]},{"k":"p","r":[{"t":"　プラットフォームで、"},{"b":"真黒","f":"まっくろ"},{"t":"に、うようよと多人数に取巻かれた中に、すっくと立って、山が彩る、"},{"b":"目瞼","f":"まぶた"},{"t":"の紅梅。"},{"b":"黄金","f":"きん"},{"t":"を"},{"b":"溶","f":"とか"},{"t":"す炎のごとき妙義山の"},{"b":"錦葉","f":"もみじ"},{"t":"に対して、ハッと燃え立つ緋の片袖。二の腕に"},{"b":"颯","f":"さっ"},{"t":"と"},{"b":"飜","f":"ひるが"},{"t":"えって、雪なす小手を"},{"b":"翳","f":"かざ"},{"t":"しながら、"},{"b":"黒煙","f":"くろけむり"},{"t":"の下になり行く汽車を"},{"b":"遥","f":"はるか"},{"t":"に見送った。"}]},{"k":"p","r":[{"t":"　"},{"b":"百合若","f":"ゆりわか"},{"t":"の矢のあとも、そのかがみよ、と見返る窓に、私は急に胸迫ってなぜか思わず落涙した。"}]},{"k":"p","r":[{"t":"　つかつかと進んで、驚いた技手の手を取って握手したのである。"}]},{"k":"p","r":[{"t":"　そこで"},{"b":"知己","f":"ちかづき"},{"t":"になった。"}]},{"k":"p","r":[{"t":"大正三（一九一四）年二月"}]}]}