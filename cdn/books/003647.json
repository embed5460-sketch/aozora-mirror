"},{"t":"に、"},{"b":"空","f":"そら"},{"t":"を飛んで人を襲うと聞いた……"},{"b":"暴風雨","f":"あらし"},{"t":"の沖には、"},{"b":"海坊主","f":"うみぼうず"},{"t":"にも"},{"b":"化","f":"ばけ"},{"t":"るであろう。"}]},{"k":"p","r":[{"t":"　"},{"b":"逢魔","f":"おうま"},{"t":"ヶ時を、"},{"b":"慌","f":"あわただ"},{"t":"しく引き返して、"},{"b":"旧","f":"もと"},{"t":"来た橋へ乗る、と、"}]},{"k":"p","r":[{"t":"（きりりりり）"}]},{"k":"p","r":[{"t":"　と鳴った。この橋はやや高いから、船に乗った"},{"b":"心地","f":"ここち"},{"t":"して、まず"},{"b":"意","f":"こころ"},{"t":"を安んじたが、振り返ると、もうこれも"},{"b":"袂","f":"たもと"},{"t":"まで"},{"b":"潮","f":"しお"},{"t":"が来て、海月はひたひたと詰め寄せた。が、さすがに、ぶくぶくと其処で留った、そして、泡が"},{"b":"呼吸","f":"いき"},{"t":"をするような"},{"b":"仇光","f":"あだびかり"},{"t":"で、"}]},{"k":"p","r":[{"t":"（さっさっさっ。"}]},{"k":"p","r":[{"t":"　しゅっしゅっ、"}]},{"k":"p","r":[{"t":"　さっ、さっ！）"}]},{"k":"p","r":[{"t":"　と"},{"b":"曳々声","f":"えいえいごえ"},{"t":"で、水を押し上げようと"},{"b":"努力","f":"つとむ"},{"t":"る"},{"b":"気勢","f":"けはい"},{"t":"。"}]},{"k":"p","r":[{"t":"　"},{"b":"玄武寺","f":"げんむじ"},{"t":"の頂なる"},{"b":"砥","f":"と"},{"t":"のごとき"},{"b":"巌","f":"いわお"},{"t":"の"},{"b":"面","f":"おも"},{"t":"へ、月影が"},{"b":"颯","f":"さっ"},{"t":"とさした。――"}]}]}