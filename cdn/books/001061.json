　"},{"b":"袖形","f":"そでがた"},{"t":"の"},{"b":"押絵細工","f":"おしえざいく"},{"t":"の"},{"b":"箸","f":"はし"},{"t":"さしから、銀の振出し、という"},{"b":"華奢","f":"きゃしゃ"},{"t":"なもので、"},{"b":"小鯛","f":"こだい"},{"t":"には骨が多い、"},{"b":"柳鰈","f":"やなぎがれい"},{"t":"の"},{"b":"御馳走","f":"ごちそう"},{"t":"を思出すと、ああ、酒と"},{"b":"煙草","f":"たばこ"},{"t":"は、さるにても極りが悪い。"}]},{"k":"p","r":[{"t":"　"},{"b":"其角","f":"きかく"},{"t":"句あり。――もどかしや雛に対して"},{"b":"小盃","f":"こさかずき"},{"t":"。"}]},{"k":"p","r":[{"t":"　あの白酒を、ちょっと唇につけた"},{"b":"処","f":"ところ"},{"t":"は、"},{"b":"乳","f":"ちち"},{"t":"の味がしはしないかと思う……ちょっとですよ。"}]},{"k":"p","r":[{"t":"　――構わず"},{"b":"注","f":"つ"},{"t":"ぎねえ。"}]},{"k":"p","r":[{"t":"　なんかで、がぶがぶ"},{"b":"遣","f":"や"},{"t":"っちゃ話にならない。"}]},{"k":"p","r":[{"t":"　"},{"b":"金岡","f":"かなおか"},{"t":"の"},{"b":"萩","f":"はぎ"},{"t":"の馬、"},{"b":"飛騨","f":"ひだ"},{"t":"の"},{"b":"工匠","f":"たくみ"},{"t":"の"},{"b":"竜","f":"りゅう"},{"t":"までもなく、電燈を消して、"},{"b":"雪洞","f":"ぼんぼり"},{"t":"の影に見参らす雛の顔は、実際、"},{"b":"唯","f":"と"},{"b":"瞻","f":"み"},{"t":"れば"},{"b":"瞬","f":"またた"},{"t":"きして、やがて"},{"b":"打微笑","f":"うちほほえ"},{"t":"む。人の悪い官女のじろりと横目で見るのがある。――壇の下に寝ていると、雛の"},{"b":"話声","f":"はなしごえ"},{"t":"が聞える、と"},{"b":"小児","f":"こども"},{"t":"の時に聞いたのを、私は今も疑いたくない。"}]},{"k":"p","r":[{"t":"　で、"},{"b":"家中","f":"かちゅう"},{"t":"が寝静まると、"},{"b":"何処","f":"どこ"},{"t":"か一ケ所、"},{"b":"小屏風","f":"こびょうぶ"},{"t":"が、鶴の羽に桃を敷いて、すッと廻ろうも知れぬ。……"},{"b":"御睦","f":"おんむつ"},{"t":"ましさにつけても、壇に、余り人形の数の多いのは"},{"b":"風情","f":"ふぜい"},{"t":"がなかろう。"}]},{"k":"p","r":[{"t":"　但し、多いにも、少いにも、今私は、雛らしいものを殆ど持たぬ。母が大事にしたのは、母がなくなって"},{"b":"後","f":"のち"},{"t":"、町に大火があって皆焼けたのである。一度持出したとも聞くが、混雑に"},{"b":"紛","f":"まぎ"},{"t":"れて行方を知らない。あれほど気を入れていたのであるから、大方は例の車に乗って、雛たち、火を免れたのであろう、と思っている。"}]},{"k":"p","r":[{"t":"　その後こういう事があった。"}]},{"k":"p","r":[{"t":"　なおそれから十二、三年を過ぎてである。"}]},{"k":"p","r":[{"t":"　"},{"b":"逗子","f":"ずし"},{"t":"にいた時、静岡の町の"},{"b":"光景","f":"さま"},{"t":"が見たくって、三月の"},{"b":"中","f":"なか"},{"t":"ばと思う。一度"},{"b":"彼処","f":"あすこ"},{"t":"へ旅をした。"},{"b":"浅間","f":"せんげん"},{"t":"の"},{"b":"社","f":"やしろ"},{"t":"で、"},{"b":"釜","f":"かま"},{"t":"で甘酒を売る茶店へ休んだ時、鳩と"},{"b":"一所","f":"いっしょ"},{"t":"に"},{"b":"日南","f":"ひなた"},{"t":"ぼっこをする婆さんに、"},{"b":"阿部川","f":"あべかわ"},{"t":"の"},{"b":"川原","f":"かわら"},{"t":"で、桜の頃は土地の人が、毛氈に"},{"b":"重詰","f":"じゅうづめ"},{"t":"もので、花の"},{"b":"酒宴","f":"さかもり"},{"t":"をする、と言うのを聞いた。――阿部川の道を"},{"b":"訊","f":"たず"},{"t":"ねたについてである。――"},{"b":"都路","f":"みやこじ"},{"t":"の唄につけても、"},{"b":"此処","f":"ここ"},{"t":"を"},{"b":"府中","f":"ふちゅう"},{"t":"と覚えた身には、静岡へ来て阿部川"},{"b":"餅","f":"もち"},{"t":"を知らないでは済まぬ気がする。これを、おかしなものの異名だなぞと思われては困る。確かに、"},{"b":"豆粉","f":"きなこ"},{"t":"をまぶした餅である。"}]},{"k":"p","r":[{"t":"　"},{"b":"賤機山","f":"しずはたやま"},{"t":"、"},{"b":"浅間","f":"せんげん"},{"t":"を"},{"b":"吹降","f":"ふきおろ"},{"t":"す風の強い、寒い日で。寂しい屋敷町を抜けたり、"},{"b":"大川","f":"おおかわ"},{"t":"の"},{"b":"堤防","f":"どて"},{"t":"を伝ったりして阿部川の橋の"},{"b":"袂","f":"たもと"},{"t":"へ出て、"},{"b":"俥","f":"くるま"},{"t":"は一軒の餅屋へ入った。"}]},{"k":"p","r":[{"t":"　色白で、赤い"},{"b":"半襟","f":"はんえり"},{"t":"をした、"},{"b":"人柄","f":"ひとがら"},{"t":"な"},{"b":"島田","f":"しまだ"},{"t":"の娘が"},{"b":"唯","f":"ただ"},{"t":"一人で店にいた。"}]},{"k":"p","r":[{"t":"　――これが、"},{"b":"名代","f":"なだい"},{"t":"の阿部川だね、一盆おくれ。――"}]},{"k":"p","r":[{"t":"　と精々"},{"b":"喜多八","f":"きだはち"},{"t":"の気分を"},{"b":"漾","f":"ただよ"},{"t":"わせて、"},{"b":"突出","f":"つきだ"},{"t":"し店の"},{"b":"硝子戸","f":"がらすど"},{"t":"の中に飾った、五つばかり装ってある朱の盆へ、"},{"b":"突如","f":"いきなり"},{"t":"立って手を掛けると、娘が、まあ、と言った。"}]},{"k":"p","r":[{"t":"　――あら、看板ですわ――"}]},{"k":"p","r":[{"t":"　いや、"},{"b":"正","f":"しょう"},{"t":"のものの"},{"b":"膝栗毛","f":"ひざくりげ"},{"t":"で、"},{"b":"聊","f":"いささ"},{"t":"か気分なるものを"},{"b":"漾","f":"ただよ"},{"t":"わせ過ぎた形がある。が、"},{"b":"此処","f":"ここ"},{"t":"で早速"},{"b":"頬張","f":"ほおば"},{"t":"って、"},{"b":"吸子","f":"きびしょ"},{"t":"の"},{"b":"手酌","f":"てじゃく"},{"t":"で"},{"b":"飲","f":"や"},{"t":"った"},{"b":"処","f":"ところ"},{"t":"は、我ながら"},{"b":"頼母","f":"たのも"},{"t":"しい。"}]},{"k":"p","r":[{"t":"　ふと"},{"b":"小用場","f":"こようば"},{"t":"を借りたくなった。"}]},{"k":"p","r":[{"t":"　"},{"b":"中戸","f":"なかど"},{"t":"を開けて、土間をずッと奥へ、という"},{"b":"娘","f":"ねえ"},{"t":"さんの指図に任せて、古くて大きいその中戸を開けると、妙な"},{"b":"建方","f":"たてかた"},{"t":"、すぐに壁で、壁の窓からむこう土間の台所が見えながら、穴を抜けたように"},{"b":"鉤","f":"かぎ"},{"t":"の手に一つ曲って、暗い処をふっと出ると、"},{"b":"上框","f":"あがりかまち"},{"t":"に"},{"b":"縁","f":"えん"},{"t":"がついた、"},{"b":"吃驚","f":"びっくり"},{"t":"するほど広々とした茶の間。"},{"b":"大々","f":"だいだい"},{"t":"と"},{"b":"炉","f":"いろり"},{"t":"が切ってある。見事な事は、大名の"},{"b":"一","f":"ひと"},{"t":"たてぐらいは、楽に休めたろうと思う。薄暗い、古畳。"},{"b":"寂","f":"せき"},{"t":"として"},{"b":"人気","f":"ひとけ"},{"t":"がない。……猫もおらぬ。"},{"b":"炉","f":"ろ"},{"t":"に火の気もなく、茶釜も見えぬ。"}]},{"k":"p","r":[{"t":"　遠くで、"},{"b":"内井戸","f":"うちいど"},{"t":"の水の音が"},{"b":"水底","f":"みなそこ"},{"t":"へ響いてポタン、と鳴る。不思議に風が"},{"b":"留","f":"や"},{"t":"んで"},{"b":"寂寞","f":"ひっそり"},{"t":"した。"}]},{"k":"p","r":[{"t":"　見上げた"},{"b":"破風口","f":"はふぐち"},{"t":"は峠ほど高し、とぼんと野原へ出たような気がして、"},{"b":"縁","f":"えん"},{"t":"に添いつつ"},{"b":"中土間","f":"なかどま"},{"t":"を、"},{"b":"囲炉裡","f":"いろり"},{"t":"の前を向うへ通ると、"},{"b":"桃桜","f":"ももさくら"},{"b":"溌","f":"ぱっ"},{"t":"と輝くばかり、"},{"b":"五壇","f":"ごだん"},{"t":"一面の"},{"b":"緋毛氈","f":"ひもうせん"},{"t":"、やがて四畳半を"},{"b":"充満","f":"いっぱい"},{"t":"に雛、人形の数々。"}]},{"k":"p","r":[{"t":"　ふとその飾った形も姿も、昔の故郷の雛によく"},{"b":"肖","f":"に"},{"t":"た、と思うと、どの顔も、それよりは"},{"b":"蒼白","f":"あおじろ"},{"t":"くて、"},{"b":"衣","f":"きぬ"},{"t":"も"},{"b":"冠","f":"かむり"},{"t":"も"},{"b":"古雛","f":"ふるびな"},{"t":"の、"},{"b":"丈","f":"たけ"},{"t":"が二倍ほど大きかった。"}]},{"k":"p","r":[{"t":"　薄暗い"},{"b":"白昼","f":"まひる"},{"t":"の影が一つ一つに皆"},{"b":"映","f":"うつ"},{"t":"る。"}]},{"k":"p","r":[{"t":"　"},{"b":"背後","f":"うしろ"},{"t":"の"},{"b":"古襖","f":"ふるぶすま"},{"t":"が半ば"},{"b":"開","f":"あ"},{"t":"いて、奥にも一つ見える小座敷に、また五壇の雛がある。不思議や、"},{"b":"蒔絵","f":"まきえ"},{"t":"の車、雛たちも、それこそ"},{"b":"寸分","f":"すんぶん"},{"b":"違","f":"たが"},{"t":"わない"},{"b":"古郷","f":"ふるさと"},{"t":"のそれに似た、と思わず"},{"b":"伸上","f":"のびあが"},{"t":"りながら、ふと心づくと、前の雛壇におわするのが、いずれも"},{"b":"尋常","f":"ただ"},{"t":"の形でない。雛は両方さしむかい、官女たちは、横顔やら、"},{"b":"俯向","f":"うつむ"},{"t":"いたの。お"},{"b":"囃子","f":"はやし"},{"t":"はぐるり、と寄って、"},{"b":"鼓","f":"つづみ"},{"t":"の"},{"b":"調糸","f":"しらべ"},{"t":"を"},{"b":"緊","f":"し"},{"t":"めたり、"},{"b":"解","f":"と"},{"t":"いたり、"},{"b":"御殿火鉢","f":"ごてんひばち"},{"t":"も楽屋の"},{"b":"光景","f":"ありさま"},{"t":"。"}]},{"k":"p","r":[{"t":"　私は"},{"b":"吃驚","f":"びっくり"},{"t":"して"},{"b":"飛退","f":"とびの"},{"t":"いた。"}]},{"k":"p","r":[{"t":"　敷居の外の、"},{"b":"苔","f":"こけ"},{"t":"の生えた"},{"b":"内井戸","f":"うちいど"},{"t":"には、いま"},{"b":"汲","f":"く"},{"t":"んだような"},{"b":"釣瓶","f":"つるべ"},{"t":"の"},{"b":"雫","f":"しずく"},{"t":"、――"},{"b":"背戸","f":"せど"},{"t":"は桃もただ枝の"},{"b":"中","f":"うち"},{"t":"に、真黄色に咲いたのは"},{"b":"連翹","f":"れんぎょう"},{"t":"の花であった。"}]},{"k":"p","r":[{"t":"　帰りがけに"},{"b":"密","f":"そっ"},{"t":"と通ると、何事もない。"},{"b":"襖","f":"ふすま"},{"t":"の奥に雛はなくて、前の壇のも、"},{"b":"烏帽子","f":"えぼし"},{"t":"一つ位置のかわったのは見えなかった。――この時に"},{"b":"慄然","f":"ぞっ"},{"t":"とした。"}]},{"k":"p","r":[{"t":"　風はそのまま"},{"b":"留","f":"や"},{"t":"んでいる。広い河原に"},{"b":"霞","f":"かすみ"},{"t":"が流れた。渡れば"},{"b":"鞠子","f":"まりこ"},{"t":"の"},{"b":"宿","f":"しゅく"},{"t":"と聞く……梅、"},{"b":"若菜","f":"わかな"},{"t":"の句にも聞える。少し渡って見よう。"},{"b":"橋詰","f":"はしづめ"},{"t":"の、あの"},{"b":"大樹","f":"たいじゅ"},{"t":"の柳の枝のすらすらと"},{"b":"浅翠","f":"あさみどり"},{"t":"した下を通ると、樹の根に一枚、"},{"b":"緋","f":"ひ"},{"t":"の"},{"b":"毛氈","f":"もうせん"},{"t":"を敷いて、四隅を美しい河原の石で"},{"b":"圧","f":"おさ"},{"t":"えてあった。"},{"b":"雛市","f":"ひないち"},{"t":"が立つらしい、が、"},{"b":"絵合","f":"えあわせ"},{"t":"の貝一つ、"},{"b":"誰","f":"たれ"},{"t":"もおらぬ。"},{"b":"唯","f":"と"},{"t":"、二、三"},{"b":"町","f":"ちょう"},{"t":"春の真昼に、人通りが一人もない。"},{"b":"何故","f":"なぜ"},{"t":"か"},{"b":"憚","f":"はばか"},{"t":"られて、手を触れても見なかった。緋の毛氈は、"},{"b":"何処","f":"どこ"},{"t":"のか座敷から柳の"},{"b":"梢","f":"こずえ"},{"t":"を"},{"b":"倒","f":"さかさま"},{"t":"に映る雛壇の影かも知れない。夢を見るように、橋へかかると、これも白い虹が来て"},{"b":"群青","f":"ぐんじょう"},{"t":"の水を飲むようであった。あれあれ雀が飛ぶように、おさえの"},{"b":"端","f":"はし"},{"t":"の石がころころと動くと、"},{"b":"柔","f":"やわら"},{"t":"かい風に毛氈を"},{"b":"捲","f":"ま"},{"t":"いて、ひらひらと柳の"},{"b":"下枝","f":"したえだ"},{"t":"に"},{"b":"搦","f":"から"},{"t":"む。"}]},{"k":"p","r":[{"t":"　私は愕然として火を思った。"}]},{"k":"p","r":[{"t":"　"},{"b":"何処","f":"どこ"},{"t":"ともなしに、キリリキリリと、"},{"b":"軋","f":"きし"},{"t":"る"},{"b":"轅","f":"ながえ"},{"t":"の車の"},{"b":"響","f":"ひびき"},{"t":"。"}]},{"k":"p","r":[{"t":"　"},{"b":"鞠子","f":"まりこ"},{"t":"は霞む"},{"b":"長橋","f":"ながばし"},{"t":"の阿部川の橋の板を、あっちこっち、ちらちらと"},{"b":"陽炎","f":"かげろう"},{"t":"が遊んでいる。"}]},{"k":"p","r":[{"t":"　時に"},{"b":"蒼空","f":"あおぞら"},{"t":"に富士を見た。"}]},{"k":"p","r":[{"t":"　若き娘に"},{"b":"幸","f":"さち"},{"t":"あれと、餅屋の前を"},{"b":"通過","f":"とおりす"},{"t":"ぎつつ、"}]},{"k":"p","r":[{"t":"　――若い"},{"b":"衆","f":"しゅ"},{"t":"、"},{"b":"綺麗","f":"きれい"},{"t":"な娘さんだね、いい"},{"b":"婿","f":"むこ"},{"t":"さんが持たせたいね――"}]},{"k":"p","r":[{"t":"　――ええ、餅屋の婿さんは知りませんが、向う側のあの長い塀、それ、柳のわきの裏門のありますお"},{"b":"邸","f":"やしき"},{"t":"は、……旦那、"},{"b":"大財産家","f":"だいざいさんか"},{"t":"でございましてな。つい近い頃、東京から、それはそれは美しい奥さんが見えましたよ――"}]},{"k":"p","r":[{"t":"　何とこうした時は、見ぬ恋にも"},{"b":"憧憬","f":"あこが"},{"t":"れよう。"}]},{"k":"p","r":[{"t":"　"},{"b":"欲","f":"ほし"},{"t":"いのは――もしか出来たら――"},{"b":"偐紫","f":"にせむらさき"},{"t":"の"},{"b":"源氏雛","f":"げんじびな"},{"t":"、姿も"},{"b":"国貞","f":"くにさだ"},{"t":"の"},{"b":"錦絵","f":"にしきえ"},{"t":"ぐらいな、"},{"b":"花桐","f":"はなぎり"},{"t":"を第一に、"},{"b":"藤","f":"ふじ"},{"t":"の"},{"b":"方","f":"かた"},{"t":"、紫、"},{"b":"黄昏","f":"たそがれ"},{"t":"、"},{"b":"桂木","f":"かつらぎ"},{"t":"、桂木は人も知った"},{"b":"朧月夜","f":"おぼろづきよ"},{"t":"の事である。"}]},{"k":"p","r":[{"t":"　　　照りもせず、くもりも果てぬ春の"},{"b":"夜","f":"よ"},{"t":"の……"}]},{"k":"p","r":[{"t":"　この辺は"},{"b":"些","f":"ちっ"},{"t":"と酔ってるでしょう。"}]}]}