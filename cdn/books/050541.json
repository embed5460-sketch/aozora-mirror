,{"b":"傍若無人","f":"ぼうじゃくぶじん"},{"t":"で、いずれ野宿の、ここに寝てしまうつもりでいよう。舫船を旅籠とより、名所を座敷にしたようなことを"},{"b":"吐","f":"ぬか"},{"t":"す。が。"},{"b":"僅","f":"わず"},{"t":"か"},{"b":"一時","f":"ひととき"},{"t":"ばかり前、この町通り、両側の旅籠の前を、うろついて"},{"b":"歩行","f":"ある"},{"t":"いた折は、早や日も落ちて、脚にも背にも、放浪の陰の"},{"b":"漾","f":"ただよ"},{"t":"った、見るからみじめな様子であった。"}]},{"k":"blank"},{"k":"h","level":2,"r":[{"t":"三"}]},{"k":"blank"},{"k":"p","r":[{"t":"　"},{"b":"黄昏","f":"たそがれ"},{"t":"に、"},{"b":"御泊","f":"おとまり"},{"t":"を待つ"},{"b":"宿引女","f":"やどひきおんな"},{"t":"の、"},{"b":"廂","f":"ひさし"},{"t":"はずれの"},{"b":"床几","f":"しょうぎ"},{"t":"に掛けて、島田、"},{"b":"円髷","f":"まるまげ"},{"t":"、"},{"b":"銀杏返","f":"いちょうがえし"},{"t":"、"},{"b":"撫","f":"なで"},{"t":"つけ髪の夕化粧、姿を"},{"b":"斜","f":"ななめ"},{"t":"に腰を掛けて、"},{"b":"浅葱","f":"あさぎ"},{"t":"に、白に、紅に、ちらちら"},{"b":"手絡","f":"てがら"},{"t":"の色に通う、"},{"b":"団扇","f":"うちわ"},{"t":"の絵を動かす"},{"b":"状","f":"さま"},{"t":"、もの言う声も"},{"b":"媚","f":"なまめ"},{"t":"かしく"},{"b":"傾城町","f":"けいせいまち"},{"t":"の風情がある。"}]},{"k":"p","r":[{"t":"　浦づたいなる掃いたような白い道は、両側に軒を並べた、"},{"b":"家居","f":"いえい"},{"t":"の中を、あの"},{"b":"注連","f":"しめ"},{"t":"を張った岩に続く……、松の"},{"b":"蒔絵","f":"まきえ"},{"t":"の貝の一筋道。"}]},{"k":"p","r":[{"t":"　"},{"b":"氷店","f":"こおりみせ"},{"t":"、"},{"b":"休茶屋","f":"やすみぢゃや"},{"t":"、赤福売る店、一膳めし、"},{"b":"就中","f":"なかんずく"},{"t":"、"},{"b":"鵯","f":"ひよどり"},{"t":"の鳴くように、けたたましく"},{"b":"往来","f":"ゆきき"},{"t":"を呼ぶ、貝細工、寄木細工の小女どもも、昼から夜へ"},{"b":"日脚","f":"ひあし"},{"t":"の淀みに"},{"b":"商売","f":"あきない"},{"t":"の"},{"b":"逢魔","f":"おうま"},{"t":"ヶ"},{"b":"時","f":"どき"},{"t":"、"},{"b":"一時","f":"ひとしきり"},{"b":"鳴","f":"なり"},{"t":"を鎮めると、出女の髪が黒く、"},{"b":"白粉","f":"おしろい"},{"t":"が白く成る。"}]},{"k":"p","r":[{"t":"　優い声で、"}]},{"k":"p","r":[{"t":"「もし、お泊りかな。」"}]},{"k":"p","r":[{"t":"「お泊りやすえ。」"}]},{"k":"p","r":[{"t":"　"},{"b":"彼方","f":"あっち"},{"t":"でも、お泊りやす、"},{"b":"此方","f":"こっち"},{"t":"でも、お泊りやす、と愛嬌声の口許は、松葉牡丹の紅である。"}]},{"k":"p","r":[{"t":"「泊るよ。」"}]},{"k":"p","r":[{"t":"　"},{"b":"其処","f":"そこ"},{"t":"へ、"},{"b":"突掛","f":"つッか"},{"t":"けに　紺がすりの汗ばんだ"},{"b":"道中","f":"どうちゅう"},{"t":"を持って"},{"b":"行","f":"ゆ"},{"t":"くと、"}]},{"k":"p","r":[