に"},{"b":"入浸","f":"いりひた"},{"t":"り、不義の快楽を貪りしが、"},{"b":"一月","f":"ひとつき"},{"t":"こそ"},{"b":"可","f":"よ"},{"t":"けれ、二月こそ可けれ、三月四月に及びては、精神"},{"b":"瞢騰","f":"もうとう"},{"t":"として常に"},{"b":"酔","f":"よえ"},{"t":"るが如く、"},{"b":"身躰","f":"からだ"},{"t":"も"},{"b":"太","f":"いた"},{"t":"く衰弱しつ、元気次第に消耗せり。"}]},{"k":"p","r":[{"t":"　こは火の如き婦人の熱情のために心身"},{"b":"両","f":"ふたつ"},{"t":"ながら溶解し去らるるならんと、ようやく渠を恐るる気色を、早く"},{"b":"暁","f":"さと"},{"t":"りたる大年増は、我子ともすべき美少年の、"},{"b":"緑陰","f":"りょくいん"},{"t":"深き所を"},{"b":"厭","f":"いと"},{"t":"いて、他に寒紅梅一枝の春をや探るならんと邪推なし、"},{"b":"瞋恚","f":"しんい"},{"t":"を燃す胸の炎は一段の熱を加えて、鉄火五躰を"},{"b":"烘","f":"あぶ"},{"t":"るにぞ、美少年は最早数分時も"},{"b":"得堪","f":"えた"},{"t":"えずなりて、辛くもその家を遁走したりけるが家に帰らんも勘当の身なり、"},{"b":"且","f":"かつ"},{"t":"は婦人に"},{"b":"捜出","f":"さがしい"},{"t":"だされんことを"},{"b":"慮","f":"おもんぱか"},{"t":"りて、遂に予を"},{"b":"便","f":"たよ"},{"t":"りしなり。予は快く"},{"b":"匿","f":"かくま"},{"t":"いつ。"}]},{"k":"p","r":[{"t":"　しかるに美少年はなお心を"},{"b":"安","f":"やす"},{"t":"んせずして言いぬ。"}]},{"k":"p","r":[{"t":"「"},{"b":"彼","f":"か"},{"t":"の婦人は一種の魔法づかいともいうべき者なり。いつぞや召使の婢が金子を"},{"b":"掠","f":"かす"},{"t":"めて出奔せしに、お艶は"},{"b":"争","f":"いか"},{"t":"で"},{"b":"遁","f":"のが"},{"t":"すべきとて、直ちに"},{"b":"足留","f":"あしどめ"},{"t":"の法といえるを修したりき、それかあらぬか件の婢は、脱走せし翌日より"},{"b":"遽","f":"にわか"},{"t":"に足の"},{"b":"疾","f":"やまい"},{"t":"起りて、"},{"b":"一寸","f":"ちょっと"},{"t":"の歩行もなり難く、間近の家に潜みけるを直ちに引戻せしことを目撃したりき。その他咒詛、"},{"b":"禁厭","f":"きんえん"},{"t":"等、"},{"b":"苟","f":"いやしく"},{"t":"も"},{"b":"幽冥","f":"ゆうめい"},{"t":"の力を"},{"b":"仮","f":"か"},{"t":"りて為すべきを知らざるはなし。"}]},{"k":"p","r":[{"t":"　さるからに"},{"b":"口説","f":"くぜつ"},{"t":"の際も常に予を戒めて、ここな性悪者め、"},{"b":"他","f":"あだ"},{"t":"し"},{"b":"女子","f":"おなご"},{"t":"に見替えて"},{"b":"酷","f":"むご"},{"t":"くも我を棄つることあらば"},{"b":"呪殺","f":"のろいころ"},{"t":"してくれんずと、凄まじかりし顔色は今もなお"},{"b":"眼","f":"まなこ"},{"t":"に在り。」"}]},{"k":"p","r":[{"t":"　と繰返しては歎息しつ。予は万々"},{"b":"然","f":"さ"},{"t":"ることのあるべからざる理をもて説諭すれども、"},{"b":"渠","f":"かれ"},{"t":"は常に"},{"b":"戦々兢々","f":"せんせんきょうきょう"},{"t":"として"},{"b":"楽","f":"たのし"},{"t":"まざりしを、"},{"b":"密","f":"ひそ"},{"t":"かに"},{"b":"持余","f":"もてあま"},{"t":"せしが、今"},{"b":"眼前","f":"まのあたり"},{"t":"一本杉の五寸釘を見るに及びて予は"},{"b":"思","f":"おもい"},{"b":"半","f":"なか"},{"t":"ばに過ぎたり。"}]},{"k":"blank"},{"k":"h","level":2,"r":[{"t":"上の二"}]},{"k":"blank"},{"k":"p","r":[{"t":"　"},{"b":"有恁","f":"かくて"},{"t":"予は憐むべき美少年の為に、"},{"b":"咒詛","f":"のろい"},{"t":"の釘を"},{"b":"抜棄","f":"ぬきす"},{"t":"てなんと試みしに、"},{"b":"執念","f":"しゅうね"},{"t":"き鉄槌の一打は到底指の力の及ぶ所にあらざりき。"}]},{"k":"p","r":[{"t":"　"},{"b":"洵","f":"まこと"},{"t":"に八才の龍女がその功力を以て成仏せしというなる、法華経の何の巻かを、"},{"b":"誦","f":"ずん"},{"t":"じては抜き、誦じては抜くにあらざれば、得て抜くべからざるものをや。"}]},{"k":"p","r":[{"t":"　誰にもあれ人無き処にて、他に見せまじき所業を為せばその事の善悪に関わらず、自から良心の咎むるものなり。"}]},{"k":"p","r":[{"t":"　予も何となく"},{"b":"後顧","f":"うしろぐら"},{"t":"き心地して、人もや見んと"},{"b":"危","f":"あやぶ"},{"t":"みつつ今一息と"},{"b":"踏張","f":"ふんば"},{"t":"る機会に、提灯の火を"},{"b":"揺消","f":"ゆりけ"},{"t":"したり。"},{"b":"黒白","f":"こくびゃく"},{"t":"も分かぬ闇夜となりぬ。予は茫然として自失したりき。時に遠く一点の"},{"b":"火光","f":"あかり"},{"t":"を認めつ。"}]},{"k":"p","r":[{"t":"　"},{"b":"良","f":"やや"},{"t":"有りて予はその燈影なるを"},{"b":"確","f":"たしか"},{"t":"めたり。"},{"b":"軈","f":"やが"},{"t":"て視線の及ぶべき距離に"},{"b":"近","f":"ちかづ"},{"t":"きぬ。"}]},{"k":"p","r":[{"t":"　予が"},{"b":"曩","f":"さき"},{"t":"に諸君に向いて、凄まじきものの経験を有せりと謂いしは"},{"b":"是","f":"ここ"},{"t":"なり。"}]},{"k":"p","r":[{"t":"　予は"},{"b":"謂","f":"い"},{"t":"えらく、偶然人の秘密を見るは"},{"b":"可","f":"よ"},{"t":"し。"},{"b":"然","f":"しか"},{"t":"れども秘密を行う者をして、人目を憚る"},{"b":"行","f":"ふるまい"},{"t":"を、見られたりと心着かしめんは妙ならず。ために"},{"b":"由","f":"よし"},{"t":"無き"},{"b":"怨","f":"うらみ"},{"t":"を負いて、迷惑することもありぬべしと、四辺を見廻わして、身を隠すべき所を"},{"b":"覓","f":"もと"},{"t":"めしに、この辺には"},{"b":"屡","f":"しばしば"},{"t":"見る、山腹を横に"},{"b":"穿","f":"うが"},{"t":"ちたる洞穴を見出したり。"}]},{"k":"p","r":[{"t":"　要こそあれと身を翻して、早くも洞中に潜むと"},{"b":"与","f":"とも"},{"t":"に、"},{"b":"燈","f":"ともしび"},{"t":"の主は間近に来りぬ。一個の婦人なり。予は燈影を見し"},{"b":"始","f":"はじめ"},{"t":"より、"},{"b":"今夜","f":"こよい"},{"t":"満願に当るべき咒詛主の、"},{"b":"驚破","f":"すわ"},{"t":"や来ると思いしなりき。"}]},{"k":"p","r":[{"t":"　"},{"b":"霜威","f":"そうい"},{"t":"の"},{"b":"凜冽","f":"りんれつ"},{"t":"たる冬の夜に、見る目も寒く水を浴びしと"},{"b":"覚","f":"おぼ"},{"t":"しくて、真白の"},{"b":"単衣","f":"ひとえ"},{"t":"は濡紙を貼りたる如く、よれよれに手足に"},{"b":"絡","f":"まと"},{"t":"いて、全身の肉附は"},{"b":"顕然","f":"あらわ"},{"t":"に透きて見えぬ。"},{"b":"霑","f":"うるお"},{"t":"いたる緑の黒髪は"},{"b":"颯","f":"さっ"},{"t":"と乱れて、背と胸とに振分けたり。想うに、谷間を流るる"},{"b":"一条","f":"ひとすじ"},{"t":"の小川は、此処に詣ずる行者輩の身を"},{"b":"浄","f":"きよ"},{"t":"むる処なれば、婦人も"},{"b":"彼処","f":"あすこ"},{"t":"にこそ"},{"b":"垢離","f":"こり"},{"t":"を取れりしならめ。"}]},{"k":"p","r":[{"t":"　と見る間に婦人は一本杉の下に立寄りたり。"}]},{"k":"p","r":[{"t":"　ここに於て予がその婦人を目して誰なりとせしかは、予が言を待たずして、諸君は"},{"b":"疾","f":"とう"},{"t":"に推し給わむ。"}]},{"k":"p","r":[{"t":"　予は洞中に声を呑みて、その"},{"b":"為","f":"せ"},{"t":"んようを"},{"b":"窺","f":"うかが"},{"t":"いたり。渠は然りとも知らざれば、金燈籠に類したる手提の燈火を傍に差置き、足を爪立てて天を仰ぎ、腰を"},{"b":"屈","f":"かが"},{"t":"めて地に伏し、合掌しつ、礼拝しつ、頭を木の幹に打当つるなど、今や天地は己が独有に"},{"b":"皈","f":"かえ"},{"t":"せる時なるを信じて、他に我を見る一双の眼あるを知らざる者にあらざるよりは、到底"},{"b":"裏恥","f":"うらはず"},{"t":"かしく、為しがたかるべき、奇異なる"},{"b":"挙動","f":"ふるまい"},{"t":"を"},{"b":"恣","f":"ほしいまま"},{"t":"にしたりとせよ。"}]},{"k":"p","r":[{"t":"　最後に婦人は口中より一本の釘を"},{"b":"吐","f":"はき"},{"t":"出して、これを彼二十一歳の男子と記したる紙片に"},{"b":"推当","f":"おしあ"},{"t":"て、鉄槌をもて"},{"b":"丁々","f":"ちょうちょう"},{"t":"と打ちたりけり。"}]},{"k":"p","r":[{"t":"　時に"},{"b":"万籟","f":"ばんらい"},{"b":"寂","f":"せき"},{"t":"として、地に虫の這う音も無く、天は今にも"},{"b":"降","f":"ふら"},{"t":"せんずる、"},{"b":"霙","f":"みぞれ"},{"t":"か、雪か、"},{"b":"霰","f":"あられ"},{"t":"か、雨かを、雲の"},{"b":"袂","f":"たもと"},{"t":"に蔵しつつ微音をだに語らざる、その"},{"b":"静","f":"しずか"},{"t":"さに睡りたりし耳元に、「カチン」と響く鉄槌の音は、鼓膜を"},{"b":"劈","f":"つんざ"},{"t":"きて予が腸を貫けり。"}]},{"k":"p","r":[{"t":"　続きて打込む丁々は、"},{"b":"滴々","f":"たらたら"},{"t":"冷かなる汗を誘いて、予は自から支えかぬるまでに戦慄せり。"}]},{"k":"p","r":[{"t":"　"},{"b":"剰","f":"あまつさ"},{"t":"え陰々として、"},{"b":"裳","f":"もすそ"},{"t":"は暗く、腰より上の白き婦人が、"},{"b":"長","f":"たけ"},{"t":"なる髪を"},{"b":"振乱","f":"ふりみだ"},{"t":"して"},{"b":"彳","f":"たたず"},{"t":"める、その姿の凄じさに、予は寧ろ幽霊の"},{"b":"与易","f":"くみしやす"},{"t":"さを感じてき。"}]},{"k":"p","r":[{"t":"　釘打つ音の終ると"},{"b":"侔","f":"ひとし"},{"t":"く、婦人はよろよろと身を"},{"b":"退","f":"すさ"},{"t":"りて、束ねしものの崩るる如く、地上に"},{"b":"摚","f":"どう"},{"t":"と膝を敷きぬ。"}]},{"k":"p","r":[{"t":"　予をして"},{"b":"謬","f":"あやま"},{"t":"たざらしめば、首尾好く"},{"b":"願","f":"がん"},{"t":"の満ちたるより、二十日以来"},{"b":"張詰","f":"はりつ"},{"t":"めし気の一時に"},{"b":"弛","f":"ゆる"},{"t":"みたるにやあらん。"},{"b":"良","f":"やや"},{"t":"ありて"},{"b":"渠","f":"かれ"},{"t":"の身を起し、"},{"b":"旧","f":"もと"},{"t":"来し方に"},{"b":"皈","f":"かえ"},{"t":"るを見るに、その来りし時に似もやらで、太く"},{"b":"足許","f":"あしもと"},{"t":"の"},{"b":"踽","f":"よろめ"},{"t":"きたりき。"}]}]}