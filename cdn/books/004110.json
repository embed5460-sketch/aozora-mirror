:"を"},{"b":"塗","f":"ぬ"},{"t":"れば"},{"b":"疥癬","f":"ひぜん"},{"t":"の虫さえ死んでしまうという毒草だそうで、食べるどころのものでは無い危いものだということであって、自分も全く驚いてしまった。こんな"},{"b":"長閑気","f":"のんき"},{"t":"な"},{"b":"仙人","f":"せんにん"},{"t":"じみた"},{"b":"閑遊","f":"かんゆう"},{"t":"の間にも、危険は"},{"b":"伏在","f":"ふくざい"},{"t":"しているものかと、今更ながら呆れざるを得なかった。"}]},{"k":"p","r":[{"t":"　ペンペン草の返礼にあれを"},{"b":"喫","f":"た"},{"t":"べさせられては、と土耳舌帽氏も恐れ入った。人々は大笑いに笑い、自分も笑ったが、自分の"},{"b":"慙入","f":"はじい"},{"t":"った感情は、"},{"b":"洒々落々","f":"しゃしゃらくらく"},{"t":"たる人々の間の事とて、やがて水と流され風と"},{"b":"払","f":"はら"},{"t":"われて何の"},{"b":"痕","f":"あと"},{"t":"も"},{"b":"留","f":"とど"},{"t":"めなくなった。"}]},{"k":"p","r":[{"t":"　その日はなお"},{"b":"種々","f":"いろいろ"},{"t":"のものを"},{"b":"喫","f":"きっ"},{"t":"したが、今"},{"b":"詳","f":"くわ"},{"t":"しく思出すことは出来ない。その後のある日にもまた自分が有毒のものを採って"},{"b":"叱","f":"しか"},{"t":"られたことを"},{"b":"記憶","f":"きおく"},{"t":"しているが、三十余年前のかの晩春の"},{"b":"一日","f":"いちじつ"},{"t":"は"},{"b":"霞","f":"かすみ"},{"t":"の"},{"b":"奥","f":"おく"},{"t":"の花のように楽しい面白かった情景として、春ごとの頭に浮んで来る。"}]},{"k":"p","r":[{"t":"（昭和三年五月）"}]}]}