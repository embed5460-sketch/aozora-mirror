{"id":"053495","title":"老いたるえびのうた","author":"室生犀星","authorId":"001579","blocks":[{"k":"p","r":[{"t":"けふはえびのように悲しい"}]},{"k":"p","r":[{"b":"角","f":"つの"},{"t":"やらひげやら"}]},{"k":"p","r":[{"t":"とげやら一杯生やしてゐるが"}]},{"k":"p","r":[{"t":"どれが悲しがつてゐるのか判らない。"}]},{"k":"blank"},{"k":"p","r":[{"t":"ひげにたづねて見れば"}]},{"k":"p","r":[{"t":"おれではないといふ。"}]},{"k":"p","r":[{"t":"尖つたとげに聞いて見たら"}]},{"k":"p","r":[{"t":"わしでもないといふ。"}]},{"k":"p","r":[{"t":"それでは一体誰が悲しがつてゐるのか"}]},{"k":"p","r":[{"t":"誰に聞いてみても"}]},{"k":"p","r":[{"t":"さつぱり判らない。"}]},{"k":"blank"},{"k":"p","r":[{"t":"生きてたたみを這うてゐるえせえび一疋。"}]},{"k":"p","r":[{"t":"からだじうが悲しいのだ。"}]}]}